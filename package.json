{
  "dependencies": {
    "spec-up": "^0.12.2"
  },
  "name": "verifiable-trust-spec",
  "version": "5.0",
  "description": "Verifiable Trust v5 Specification",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/verana-labs/verifiable-trust-spec.git"
  },
  "license": "Creative Commons Attribution-ShareAlike 4.0",
  "homepage": "https://github.com/verana-labs/verifiable-trust-spec",
  "bugs": {
    "url": "https://github.com/verana-labs/verifiable-trust-spec/issues"
  },
  "scripts": {
    "render": "npm run build",
    "edit": "npm run dev",
    "build": "npm run clean && npm run build:specs && node scripts/inject-favicon.js",
    "build:specs": "node -e \"import('spec-up').then(m => m.default({ nowatch: true }))\"",
    "dev": "npm run clean && npm run dev:specs",
    "dev:specs": "node -e \"import('spec-up').then(m => m.default())\"",
    "clean": "rm -rf build && mkdir build"
  }
}
